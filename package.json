{
  "name": "vibe-tour",
  "displayName": "VibeTour",
  "description": "Coding-agent-authored walkthroughs that explain codebases and recent changes beside the source in VS Code.",
  "version": "0.0.4",
  "private": true,
  "publisher": "vibetour",
  "repository": {
    "type": "git",
    "url": "https://github.com/serendipity-zk/VibeTour.git"
  },
  "homepage": "https://github.com/serendipity-zk/VibeTour#readme",
  "bugs": {
    "url": "https://github.com/serendipity-zk/VibeTour/issues"
  },
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "code walkthrough",
    "code review",
    "codex",
    "claude code",
    "onboarding"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:vibe-tour-lessons",
    "onCommand:vibeTour.startChapter",
    "onCommand:vibeTour.stopChapter",
    "onCommand:vibeTour.resetChapter",
    "onCommand:vibeTour.openStep",
    "onCommand:vibeTour.completeCurrent",
    "onCommand:vibeTour.copyStepContext",
    "onCommand:vibeTour.previous",
    "onCommand:vibeTour.next",
    "onCommand:vibeTour.openRelated",
    "onCommand:vibeTour.back",
    "onCommand:vibeTour.refreshLessons",
    "onCommand:vibeTour.installAuthoringSkill",
    "onCommand:vibeTour.showLessons",
    "onCommand:vibeTour.deleteLesson"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeTour.startChapter",
        "title": "VibeTour: Start or Resume Chapter",
        "icon": "$(play)"
      },
      {
        "command": "vibeTour.stopChapter",
        "title": "VibeTour: Stop Chapter",
        "icon": "$(debug-stop)"
      },
      {
        "command": "vibeTour.resetChapter",
        "title": "VibeTour: Reset Chapter",
        "icon": "$(debug-restart)"
      },
      {
        "command": "vibeTour.openStep",
        "title": "VibeTour: Open Step"
      },
      {
        "command": "vibeTour.completeCurrent",
        "title": "VibeTour: Mark Current Step Done",
        "icon": "$(check)"
      },
      {
        "command": "vibeTour.copyStepContext",
        "title": "VibeTour: Copy Step YAML",
        "icon": "$(copy)"
      },
      {
        "command": "vibeTour.previous",
        "title": "VibeTour: Previous Step",
        "icon": "$(arrow-left)"
      },
      {
        "command": "vibeTour.next",
        "title": "VibeTour: Next Step",
        "icon": "$(arrow-right)"
      },
      {
        "command": "vibeTour.openRelated",
        "title": "VibeTour: Open Related Code"
      },
      {
        "command": "vibeTour.back",
        "title": "VibeTour: Back to Lesson Step"
      },
      {
        "command": "vibeTour.refreshLessons",
        "title": "VibeTour: Refresh Lessons",
        "icon": "$(refresh)"
      },
      {
        "command": "vibeTour.installAuthoringSkill",
        "title": "VibeTour: Install Lesson Authoring Skill",
        "icon": "$(tools)"
      },
      {
        "command": "vibeTour.showLessons",
        "title": "VibeTour: Show Lessons"
      },
      {
        "command": "vibeTour.deleteLesson",
        "title": "VibeTour: Delete Lesson",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibe-tour",
          "title": "VibeTour",
          "icon": "media/book.svg"
        }
      ]
    },
    "views": {
      "vibe-tour": [
        {
          "id": "vibe-tour-lessons",
          "name": "Lessons"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vibe-tour-lessons",
        "contents": "No lessons yet. Install the authoring skill to generate validated VibeTour YAML with Codex or Claude Code.\n[Install or Update Authoring Skill](command:vibeTour.installAuthoringSkill)",
        "when": "!vibeTour.hasLessonErrors && vibeTour.needsSkillInstall"
      },
      {
        "view": "vibe-tour-lessons",
        "contents": "No valid lessons are loaded. Check the Problems view for YAML errors, or install the authoring skill to generate a valid lesson.\n[Install or Update Authoring Skill](command:vibeTour.installAuthoringSkill)",
        "when": "vibeTour.hasLessonErrors && vibeTour.needsSkillInstall"
      },
      {
        "view": "vibe-tour-lessons",
        "contents": "No lessons yet. Ask Codex or Claude Code to generate one with the installed VibeTour authoring skill.",
        "when": "!vibeTour.hasLessonErrors && !vibeTour.needsSkillInstall"
      },
      {
        "view": "vibe-tour-lessons",
        "contents": "No valid lessons are loaded. Check the Problems view for YAML errors.",
        "when": "vibeTour.hasLessonErrors && !vibeTour.needsSkillInstall"
      }
    ],
    "menus": {
      "comments/commentThread/title": [
        {
          "command": "vibeTour.previous",
          "when": "commentController == vibeTour.comments && commentThread =~ /hasPrevious/",
          "group": "inline@1"
        },
        {
          "command": "vibeTour.next",
          "when": "commentController == vibeTour.comments && commentThread =~ /hasNext/",
          "group": "inline@2"
        },
        {
          "command": "vibeTour.completeCurrent",
          "when": "commentController == vibeTour.comments && commentThread =~ /incomplete/",
          "group": "inline@3"
        },
        {
          "command": "vibeTour.stopChapter",
          "when": "commentController == vibeTour.comments",
          "group": "inline@4"
        },
        {
          "command": "vibeTour.copyStepContext",
          "when": "commentController == vibeTour.comments",
          "group": "inline@5"
        },
        {
          "command": "vibeTour.resetChapter",
          "when": "commentController == vibeTour.comments",
          "group": "inline@6"
        }
      ],
      "view/item/context": [
        {
          "command": "vibeTour.deleteLesson",
          "when": "view == vibe-tour-lessons && viewItem == codeLesson",
          "group": "inline@1"
        },
        {
          "command": "vibeTour.startChapter",
          "when": "view == vibe-tour-lessons && viewItem == codeLessonChapter",
          "group": "inline@1"
        },
        {
          "command": "vibeTour.stopChapter",
          "when": "view == vibe-tour-lessons && viewItem == codeLessonChapterActive",
          "group": "inline@1"
        },
        {
          "command": "vibeTour.resetChapter",
          "when": "view == vibe-tour-lessons && viewItem =~ /codeLessonChapter/",
          "group": "inline@2"
        }
      ],
      "view/title": [
        {
          "command": "vibeTour.installAuthoringSkill",
          "when": "view == vibe-tour-lessons && vibeTour.needsSkillInstall",
          "group": "navigation@1"
        },
        {
          "command": "vibeTour.refreshLessons",
          "when": "view == vibe-tour-lessons",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "VibeTour",
      "properties": {
        "codeLessons.searchPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.code-lessons/**/*.yaml",
            "**/.code-lessons/**/*.yml"
          ],
          "scope": "resource",
          "description": "Glob patterns, relative to each workspace folder, used to discover code lesson YAML files, including lessons owned by nested repositories."
        },
        "codeLessons.autoReload": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Automatically reload lessons when discovered YAML files change."
        }
      }
    }
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "scripts": {
    "build": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "check": "node --check extension.js && node --check lessonLoader.js && node --check skillInstaller.js",
    "test": "node --test test/*.test.js",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1"
  }
}
